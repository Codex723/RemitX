// Prisma schema for RemitX
// Database: CockroachDB (Postgres-compatible)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum KycStatus {
  pending
  verified
  rejected
}

enum TransactionStatus {
  pending
  validating
  confirmed
  failed
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  stellarPublicKey String? @unique
  kycStatus      KycStatus @default(pending)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  transactions   Transaction[]

  @@map("users")
}

model Transaction {
  id               String            @id @default(cuid())
  userId           String
  fromAsset        String
  toAsset          String
  fromAmount       String            // stored as string to avoid precision loss with decimals
  toAmount         String?
  recipientAddress String
  stellarTxHash    String?
  status           TransactionStatus @default(pending)
  xdr              String?           // unsigned XDR for client-side signing
  createdAt        DateTime          @default(now())
  confirmedAt      DateTime?
  updatedAt        DateTime          @updatedAt

  user             User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("transactions")
}

model Rate {
  id        String   @id @default(cuid())
  fromAsset String
  toAsset   String
  rate      String   // stored as string to avoid precision loss
  fetchedAt DateTime @default(now())

  @@unique([fromAsset, toAsset])
  @@map("rates")
}